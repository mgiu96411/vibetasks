{
  "name": "vibe-tasks",
  "version": "1.0.0",
  "description": "Local-first desktop task manager and Claude Code MCP companion",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": ["shared", "mcp", "app"],
  "scripts": {
    "mcp:build": "npm -w mcp run build",
    "mcp:test": "npm -w mcp run test",
    "vibetasks": "npm -w mcp run cli --",
    "app": "npm -w app run tauri dev",
    "app:build": "npm -w app run tauri build",
    "app:open": "open 'app/src-tauri/target/release/bundle/macos/Vibe Tasks.app'",
    "app:install": "zsh scripts/install-app.sh",
    "app:install:fast": "zsh scripts/install-app.sh --skip-build",
    "app:check": "zsh scripts/app-check.sh",
    "phone:snapshot": "npm -w mcp run snapshot",
    "seed:demo": "node scripts/seed-demo.mjs"
  }
}
